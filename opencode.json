{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "apiKey": "ctx7sk-4a308489-1620-4ed4-a902-530b646a1d8f",
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "-y", "@krazor/shadcn-mcp"],
      "enabled": true
    },
    "convex": {
      "type": "local",
      "command": ["npx", "-y", "convex@latest", "mcp", "start"],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "enabled": true
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask"
  }
}
